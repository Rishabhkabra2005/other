# Supabase: Project Settings → Database
#
# DATABASE_URL — Connection pooling (Transaction mode), e.g. port 6543
#   postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL — Direct connection (Session mode), e.g. port 5432
#   postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

DATABASE_URL=""
DIRECT_URL=""

NEXTAUTH_URL="https://healthcare-platform-mu-two.vercel.app"
NEXTAUTH_SECRET="change-this-to-a-long-random-secret-in-production"

# Twilio: Console → Account → API keys & credentials
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
